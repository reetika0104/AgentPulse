# ─── PULSE Configuration ───────────────────────────────────────────
# Copy this to .env and fill in your values

# Application
APP_NAME="PULSE - AI Digital Chief of Staff"
ENVIRONMENT=production
DEBUG=false
LOG_LEVEL=INFO

# Security
SECRET_KEY=your-super-secret-key-change-this
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# AWS Configuration
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Amazon Bedrock
BEDROCK_MODEL_ID=amazon.nova-micro-v1:0
BEDROCK_MAX_TOKENS=4096

# Amazon SES
SES_SENDER_EMAIL=pulse@yourdomain.com
SES_RECIPIENT_EMAIL=you@yourdomain.com

# Amazon S3
S3_BUCKET_NAME=pulse-agent-briefs

# Google Calendar (JSON credentials string)
GOOGLE_CALENDAR_CREDENTIALS=
GOOGLE_CALENDAR_ID=primary

# Gmail (JSON credentials string)
GMAIL_CREDENTIALS=

# GitHub
GITHUB_TOKEN=ghp_your_token_here
GITHUB_USERNAME=your_username

# Weather (OpenWeatherMap)
WEATHER_API_KEY=your_openweather_api_key
WEATHER_CITY=New York

# Notion
NOTION_API_KEY=secret_your_notion_key
NOTION_DATABASE_ID=your_database_id

# RSS Feeds (comma separated)
RSS_FEEDS=https://aws.amazon.com/blogs/aws/feed/,https://blog.golang.org/feed.atom

# Telegram Bot
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# Slack
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz

# Scheduler
SCHEDULE_CRON=0 7 * * *
SCHEDULE_TIMEZONE=America/New_York

# Database
DATABASE_URL=sqlite:///./pulse.db
